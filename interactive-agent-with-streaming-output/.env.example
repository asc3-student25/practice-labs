# OpenAI API Configuration
OPENAI_API_KEY=your-api-key-here

# Model Selection — see pydantic_ai.models.KnownModelName for the
# authoritative catalog of currently supported identifiers.
# Examples: openai:gpt-5.4-mini, openai:gpt-5.4, anthropic:claude-sonnet-4-5,
#           google:gemini-2.5-flash
AI_MODEL=openai:gpt-5.4-mini

# Application Settings
LOG_LEVEL=INFO
