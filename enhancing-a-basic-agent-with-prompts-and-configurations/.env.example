OPENAI_API_KEY=your_api_key_here

# Default model used by enhanced_agent.py and test_temperature().
AI_MODEL=openai:gpt-5.4-mini

# Optional tier overrides used by compare_models() in Step 8 of the Core
# Lab. Defaults shown below match what compare_models() falls back to if
# these are unset, so you can leave them commented unless you want to
# compare different tiers (or a different provider).
# AI_MODEL_FAST=openai:gpt-5.4-nano
# AI_MODEL_CAPABLE=openai:gpt-5.4
